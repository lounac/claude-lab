# Vorlage für die Umgebungsvariablen des Backends.
# Kopiere diese Datei zu ".env" und trage deine echten Werte ein.

# Claude-API-Schlüssel (für die Stärken-Analyse).
ANTHROPIC_API_KEY=

# Supabase – für die Login-Prüfung (Auth-Guard). Beide sind öffentlich/nicht geheim.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Erlaubte Frontend-Adresse(n) für CORS (mehrere durch Komma trennbar).
# Lokal nicht nötig (localhost ist immer erlaubt); in Produktion die Vercel-URL.
FRONTEND_URL=

# Port (optional; Standard 3000, beim Hoster meist automatisch gesetzt).
# PORT=3000
