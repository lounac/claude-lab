# Vorlage für die Umgebungsvariablen des Frontends.
# Kopiere diese Datei zu ".env.local" und trage deine echten Werte ein.
# (Nur Variablen mit VITE_-Präfix sind im Browser sichtbar.)

# Supabase – Adresse + öffentlicher anon-Schlüssel.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Adresse des gehosteten NestJS-Backends (für die KI-Stärken-Analyse).
# Lokal optional – ohne Wert wird im Dev-Modus http://localhost:3000 genutzt;
# in Produktion schaltet erst ein gesetzter Wert die KI-Funktion frei.
VITE_API_URL=
